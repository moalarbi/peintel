{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/realisations/layout,_N_T_/[locale]/realisations/page,_N_T_/en/realisations"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/realisations/__PAGE__",
    "/$d$locale/realisations",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}